        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Configuration helper function (production pattern)\n",
                "def create_config_kwargs():\n",
                "    return {\n",
                "        \"dataset_name\": \"main_dataset\",\n",
                "        \"field_name\": \"phone\"  # Field to generate synthetic phones for\n",
                "    }\n",
                "\n",
                "kwargs = create_config_kwargs()\n",
                "field_name = kwargs[\"field_name\"]\n",
                "\n",
                "# Validate field exists\n",
                "print(f\"\\n🔍 Validating field configuration...\\n\")\n",
                "if field_name not in df.columns:\n",
                "    raise ValueError(\n",
                "        f\"❌ Field '{field_name}' not found in dataset!\\n\"\n",
                "        f\"Available columns: {', '.join(df.columns)}\\n\"\n",
                "        f\"Please update 'field_name' in create_config_kwargs()\"\n",
                "    )\n",
                "\n",
                "print(f\"✓ Field to process: '{field_name}'\")\n",
                "print(f\"  Unique phones: {df[field_name].nunique()}\")\n",
                "print(f\"  Sample phones:\")\n",
                "for i, phone in enumerate(df[field_name].head(5), 1):\n",
                "    print(f\"    {i}. {phone}\")\n",
                "print(f\"  Average length: {df[field_name].str.len().mean():.1f} characters\")\n",
                "\n",
                "# Create task directory\n",
                "task_dir = examples_dir / 'data_examples' / 'simple_output'\n",
                "os.makedirs(task_dir, exist_ok=True)\n",
                "print(f\"\\n✓ Task directory: {task_dir}\")\n",
                "\n",
                "# Initialize TaskReporter\n",
                "task_reporter = TaskReporter(\n",
                "    task_id=\"simple_phone_001\",\n",
                "    task_type=\"fake_phone_generation\",\n",
                "    description=\"Generate synthetic phone numbers for customer data\",\n",
                "    report_path=task_dir\n",
                ")\n",
                "print(\"✓ TaskReporter initialized\")\n",
                "\n",
                "execute_kwargs = {\"dataset_name\": kwargs[\"dataset_name\"]}\n",
                "print(f\"✓ Config kwargs: {execute_kwargs}\")\n",
                "\n",
                "# Create DataSource\n",
                "data_source = DataSource(dataframes={\"main_dataset\": df})\n",
                "print(\"✓ DataSource created\")\n",
                "\n",
                "# Setup progress tracker\n",
                "tracker = HierarchicalProgressTracker(\n",
                "    total=6,\n",
                "    description=f\"Generating synthetic phone numbers for {field_name}\",\n",
                "    unit=\"steps\",\n",
                "    track_memory=True,\n",
                "    level=0,\n",
                "    bar_format=\"{l_bar}{bar}| {n_fmt}/{total_fmt} [{elapsed}<{remaining}, {rate_fmt}]\"\n",
                ")\n",
                "print(\"✓ Progress tracker ready\")\n",
                "\n",
                "print(f\"\\n✅ Environment setup complete!\")"
            ]
