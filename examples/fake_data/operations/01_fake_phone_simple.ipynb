                "## Step 4: Configure & Execute Operation\n",
                "\n",
                "**How to use:**\n",
                "- Create FakePhoneOperation with full config\n",
                "- Use `operation.execute()` with explicit execution configs\n",
                "- Monitor progress through tracker\n",
                "\n",
                "**Key parameters:**\n",
                "- `field_name='field_name'`: Field containing phone numbers to replace\n",
                "- `mode='REPLACE'`: Modify original field (or 'ENRICH' for new field)\n",
                "- `default_country='us'`: Default country code (US/Canada = +1)\n",
                "- `country_code_field='country_code'`: Use country code information\n",
                "- `format=None`: Auto-detect format from original data\n",
                "- `preserve_country_code=True`: Keep original country codes\n",
                "- `preserve_operator_code=False`: Generate new operator codes\n",
                "- `validate_source=True`: Validate input phone numbers\n",
                "- `handle_invalid_phone='generate_new'`: Strategy for invalid numbers\n",
                "- `consistency_mechanism='mapping'`: Deterministic generation\n",
                "- `detailed_metrics=True`: Collect detailed statistics\n",
                "- `generate_visualization=True`: Create charts\n",
                "- `save_output=True`: Save to files\n",
                "- `force_recalculation=False`: Use cache if available"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Create operation with production-style configuration\n",
                "operation = FakePhoneOperation(\n",
                "    # Core parameters\n",
                "    field_name=field_name,\n",
                "    mode='REPLACE',\n",
                "    \n",
                "    # Output configuration\n",
                "    column_prefix='synthetic_',\n",
                "    output_field_name=None,\n",
                "    output_format='csv',\n",
                "    \n",
                "    # Phone generation parameters\n",
                "    default_country='us',             # US country code (+1)\n",
                "    country_code_field='country_code', # Use country code from data\n",
                "    format=None,                      # Auto-detect format\n",
                "    preserve_country_code=True,       # Keep original country codes\n",
                "    preserve_operator_code=False,     # Generate new operator codes\n",
                "    region=None,                      # No specific region\n",
                "    \n",
                "    # Validation and error handling\n",
                "    validate_source=True,             # Validate input numbers\n",
                "    handle_invalid_phone='generate_new', # Generate new for invalid\n",
                "    max_retries=3,                    # Retry failed generations\n",
                "    \n",
                "    # Metrics and monitoring\n",
                "    detailed_metrics=True,            # Enable detailed metrics\n",
                "    \n",
                "    # Consistency and privacy\n",
                "    consistency_mechanism='mapping',  # Use mapping for consistent replacement\n",
                "    key='my-secret-key-2025',         # Encryption key for PRGN\n",
                "    context_salt='phone-numbers',     # Additional randomization salt\n",
                "    save_mapping=True,                # Save phone mappings\n",
                "    \n",
                "    # Processing settings\n",
                "    use_vectorization=False,\n",
                "    parallel_processes=1,\n",
                "    use_cache=False,\n",
                "    \n",
                "    # Execution behavior\n",
                "    generate_visualization=True,\n",
                "    save_output=True,\n",
                "    force_recalculation=False\n",
                ")\n",
                "\n",
                "print(\"✓ Operation configured\")\n",
                "print(f\"  Field:                    {operation.field_name}\")\n",
                "print(f\"  Default Country:          {operation.default_country}\")\n",
                "print(f\"  Country Code Field:       {operation.country_code_field}\")\n",
                "print(f\"  Format:                   {operation.format or 'Auto-detect'}\")\n",
                "print(f\"  Preserve Country Code:    {operation.preserve_country_code}\")\n",
                "print(f\"  Preserve Operator Code:   {operation.preserve_operator_code}\")\n",
                "print(f\"  Validate Source:          {operation.validate_source}\")\n",
                "print(f\"  Handle Invalid:           {operation.handle_invalid_phone}\")\n",
                "print(f\"  Consistency:              {operation.consistency_mechanism}\")\n",
                "print(f\"  Detailed Metrics:         {operation.detailed_metrics}\")\n",
                "print(f\"  Visualizations:           {operation.generate_visualization}\")\n",
                "print(f\"  Save Output:              {operation.save_output}\")\n",
                "print(f\"  Save Mapping:             {operation.save_mapping}\")\n",
                "\n",
                "# Execute operation\n",
                "print(\"\\n\" + \"=\" * 80)\n",
                "print(\"⚙️  Executing Fake Phone Number Generation...\")\n",
                "print(\"=\" * 80 + \"\\n\")\n",
                "\n",
                "result = operation.execute(\n",
                "    data_source=data_source,\n",
                "    task_dir=task_dir,\n",
                "    reporter=task_reporter,\n",
                "    progress_tracker=tracker,\n",
                "    **execute_kwargs\n",
                ")\n",
                "\n",
                "print(\"\\n\" + \"=\" * 80)\n",
                "print(f\"✅ Operation completed!\")\n",
                "print(f\"   Status: {result.status}\")\n",
                "print(f\"   Artifacts: {len(result.artifacts)}\")\n",
                "print(\"=\" * 80)"
            ]
        },
